NEON_DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
OPENAI_API_KEY=your_openai_api_key

# Cloudflare R2
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=your_bucket_name
R2_PUBLIC_BASE_URL=https://your-public-assets-domain


# App / local preview
NEXT_PUBLIC_REMOTION_STUDIO_URL=http://localhost:3002


# Hera fallback
# Used when template routing is not high-confidence, or when template rendering fails.
HERA_API_KEY=your_hera_api_key
HERA_API_BASE_URL=https://api.hera.video/v1



# Optional polling controls for long renders.
HERA_TIMEOUT_MS=600000
HERA_POLL_INTERVAL_MS=5000

# Legacy pipeline is deprecated. Leave disabled unless you explicitly need the
# old expand → spec → code → render path as an emergency escape hatch.
ENABLE_LEGACY_PIPELINE_FALLBACK=false
